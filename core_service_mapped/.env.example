# ==== JWT СЕКРЕТЫ ====
JWT_ACCESS_SECRET=__ЗДЕСЬ_БУДЕТ_СЕКРЕТ__
JWT_REFRESH_SECRET=__ЗДЕСЬ_БУДЕТ_СЕКРЕТ__

# ==== OnlyOffice ====
